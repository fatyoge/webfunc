{
  "name": "search_task_by_dest",
  "version": "1.0.0",
  "target_origin": "http://horae.gf.com.cn/",
  "execution_mode": "browser",
  "parameters": {
    "keyword": {
      "type": "string",
      "description": "目标服务器（数据源）名称关键字",
      "default": ""
    }
  },
  "steps": [
    {
      "id": "step_0",
      "method": "POST",
      "url": "http://horae.gf.com.cn/Hive/task/list",
      "headers": {
        "content-type": "application/x-www-form-urlencoded",
        "origin": "http://horae.gf.com.cn",
        "referer": "http://horae.gf.com.cn/Hive/task/list",
        "upgrade-insecure-requests": "1",
        "user-agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36 Edg/147.0.0.0"
      },
      "body": "search_type=TS&keyword={{keyword}}&incharge_s_type=fuzzy&in_charge=&topic_name=&status=Y&task_type=&cycle_unit=&cluster="
    }
  ],
  "output": {
    "summary": "Executed search_task_by_dest"
  }
}
